<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Override badge_extra_price template to show calculated variant price instead of price adjustment -->
    <template id="badge_extra_price_calculated" name="Badge Calculated Price" inherit_id="website_sale.badge_extra_price">
        <xpath expr="//t[@t-set='price_extra']" position="replace">
            <t t-set="price_extra" t-value="ptav._get_extra_price(combination_info)"/>
            <t t-set="base_price" t-value="product.list_price"/>
            <t t-set="calculated_price" t-value="base_price + price_extra"/>
        </xpath>
        <xpath expr="//span[@class='sign_badge_price_extra']" position="replace">
            <!-- Remove the +/- sign since we're showing the total price -->
        </xpath>
        <xpath expr="//span[@class='variant_price_extra text-muted fst-italic']" position="replace">
            <span t-out="calculated_price"
                class="variant_price_calculated text-muted fst-italic"
                style="white-space: nowrap;"
                t-options='{
                    "widget": "monetary",
                    "display_currency": (website.pricelist_id or product.env.company).currency_id
                }'/>
        </xpath>
    </template>
</odoo>
