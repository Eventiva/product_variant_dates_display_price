<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Override badge_extra_price template to show calculated variant price instead of price adjustment -->
    <template id="badge_extra_price_calculated" name="Badge Calculated Price" inherit_id="website_sale.badge_extra_price">
        <xpath expr="//t[@t-set='price_extra']" position="replace">
            <t t-set="price_extra" t-value="ptav._get_extra_price(combination_info)"/>
            <t t-set="base_price" t-value="product.list_price"/>
            <t t-set="calculated_price" t-value="base_price + price_extra"/>
        </xpath>
        <xpath expr="//span[@t-if='price_extra']" position="replace">
            <span t-if="True" class="badge text-bg-primary border">
                <span t-out="calculated_price"
                    class="variant_price_calculated text-muted fst-italic"
                    style="white-space: nowrap;"
                    t-options='{
                        "widget": "monetary",
                        "display_currency": (website.pricelist_id or product.env.company).currency_id
                    }'/>
            </span>
        </xpath>
    </template>

    <!-- Override products_item template to show cheapest active variant price -->
    <template id="products_item_cheapest_price" name="Products Item Cheapest Price" inherit_id="website_sale.products_item">
        <xpath expr="//span[@t-if='template_price_vals[&quot;price_reduce&quot;] or not website.prevent_zero_price_sale']" position="replace">
            <span t-out="product._get_cheapest_active_variant_price()"
                t-options="{'widget': 'monetary', 'display_currency': website.currency_id}"/>
        </xpath>
    </template>
</odoo>
